<?xml version="1.0" encoding="utf-8" ?>
<cu3er>
	<settings>
		<auto_play>
			<defaults symbol="circular"/>
			<tweenIn x="450" y="25" width="30" height="30" tint="0xFFFFFF" alpha="0.5"/>
			<tweenOver alpha="1"/>
		</auto_play>

    	<prev_button>
			<defaults round_corners="5,5,5,5"/>
			<tweenOver tint="0xFFFFFF" />
			<tweenOut tint="0x000000" />
		</prev_button>
		
    	<prev_symbol>
			<tweenOver tint="0x000000" />			
		</prev_symbol>
		
    	<next_button>
			<defaults round_corners="5,5,5,5"/>			
			<tweenOver tint="0xFFFFFF" />
			<tweenOut tint="0x000000" />
		</next_button>
		
    	<next_symbol>
			<tweenOver tint="0x000000" />
		</next_symbol>	
			
	</settings>    

	<slides>
	
        <slide>
            <url>images/slide_1.jpg</url>
        </slide>
		<!-- changing transition beetween first & second slide -->
        <transition num="4" slicing="vertical" direction="down"/>
        <slide>
       		<url>images/slide_2.jpg</url>
        </slide>		
		<!-- changing transition beetween second & third slide -->
		<transition direction="left" shader="phong" delay="0.05"/>
		<slide>
            <url>images/slide_3.jpg</url>
        </slide>
		<transition num="4" direction="down" shader="flat" />
        <!-- transitions properties defined in transitions template -->
		<slide>
       		<url>images/slide_4.jpg</url>
        </slide>
		<transition num="4" slicing="vertical" direction="left" shader="flat" delay="0.05" z_multiplier="2" />
        <slide>
       		<url>images/slide_5.jpg</url>
        </slide>
		<transition num="4" shader="phong" delay="0.2"/>			
        <slide>
       		<url>images/slide_6.jpg</url>
        </slide>
		<transition num="3" direction="down" z_multiplier="0.9" />				
        <slide>
       		<url>images/slide_7.jpg</url>
        </slide>
		<transition num="4" direction="left" shader="flat" z_multiplier="0.8" delay="0.03"/>			
		<slide>
       		<url>images/slide_8.jpg</url>
        </slide>
		<transition num="4" direction="left" shader="flat" z_multiplier="0.8" delay="0.03"/>
		<slide>
       		<url>images/slide_9.jpg</url>
        </slide>
		<transition num="4" direction="left" shader="flat" z_multiplier="0.8" delay="0.03"/>
		<slide>
       		<url>images/slide_10.jpg</url>
        </slide>
		<transition num="4" direction="left" shader="flat" z_multiplier="0.8" delay="0.03"/>
		<slide>
       		<url>images/slide_11.jpg</url>
        </slide>
		<transition num="4" direction="left" shader="flat" z_multiplier="0.8" delay="0.03"/>
		<slide>
       		<url>images/slide_12.jpg</url>
        </slide>
		<transition num="4" direction="left" shader="flat" z_multiplier="0.8" delay="0.03"/>
	</slides>
</cu3er>

